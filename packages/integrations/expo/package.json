{
  "name": "@varlock/expo-integration",
  "description": "Expo/React Native Babel plugin to use varlock for .env file loading - adds validation, type-safety, and extra security features",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmno-dev/varlock.git",
    "directory": "packages/integrations/expo"
  },
  "type": "module",
  "main": "dist/babel-plugin.cjs",
  "types": "dist/babel-plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/babel-plugin.d.ts",
      "require": "./dist/babel-plugin.cjs",
      "import": "./dist/babel-plugin.js"
    },
    "./babel-plugin": {
      "types": "./dist/babel-plugin.d.ts",
      "require": "./dist/babel-plugin.cjs",
      "import": "./dist/babel-plugin.js"
    },
    "./metro-config": {
      "types": "./dist/metro-config.d.ts",
      "require": "./dist/metro-config.cjs",
      "import": "./dist/metro-config.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest --run"
  },
  "keywords": [
    "varlock",
    "expo",
    "react-native",
    "babel",
    "babel-plugin",
    "env",
    ".env",
    "environment variables",
    "env vars",
    "config",
    "security",
    "validation",
    "leak protection",
    "varlock-integration"
  ],
  "author": "dmno-dev",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "varlock": "workspace:^",
    "@babel/core": ">=7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "varlock": "workspace:^",
    "vitest": "catalog:"
  }
}
